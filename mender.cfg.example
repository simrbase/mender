## ============================================================
## mender.cfg.example — Mender pipeline configuration file
## Split gene detection and merging for genome annotations
## ============================================================
##
## Usage:
##   perl run_mender.pl --config myproject.cfg
##   perl run_mender.pl --config myproject.cfg --steps 1,2,3   # run specific steps
##   perl run_mender.pl --config myproject.cfg --steps 5       # run only merge
##   perl run_mender.pl --config myproject.cfg --dry_run       # preview merges only
##
## Steps:
##   1  prepare    clean protein fasta, extract GFF subsets
##   2  diamond    run diamond blastp
##   3  bedtools   run bedtools intersect for IsoSeq overlaps
##   4  find       run find_split_genes.pl
##   5  validate   run validate_merge_with_isoseq.pl (requires isoseq_gff)
##   6  merge      run merge_split_genes.pl
##   7  gt         run gt gff3validator on merged GFF (fast)
##   8  transl     run validate_merge_translation.pl (skip if run_translation_validation = no)
##   9  agat       run agat validation on pass GFF only (slow; skip if run_agat = no)
##
## Lines beginning with # are comments and are ignored.
## Leave optional values blank to skip that feature.
## ============================================================

[input]

## Full path to your genome annotation GFF3 file.
## Must be sorted parent-before-child.
## If not sorted: gt gff3 -sort -tidy -retainids your.gff > sorted.gff
gff = genomic.gff

## Genome sequence FASTA (required for step 8 translation validation).
## Used by gffread to translate merged CDS and source gene CDS into proteins.
genome_fa = genome.fa

## Protein FASTA for the genome being annotated (the query).
## Internal stop codons will be removed automatically in step 1.
proteome_fa = protein.aa.fa

## Reference proteome FASTA for diamond blastp (the subject/database).
## Should be a well-annotated proteome from a phylogenetically close species.
##
## --- REFERENCE PROTEOME SELECTION GUIDANCE ---
##
## The ideal reference is both closely related (strong blast hits, more tiling
## hits per split gene) and well-annotated (fewer false positives from reference
## misannotations). These goals are sometimes in tension. Key criteria:
##
##   Completeness: prefer proteomes with high BUSCO vertebrata scores (>90%).
##     Missing genes in the reference create blind spots — split genes whose
##     true ortholog is absent from the reference cannot be detected.
##
##   Annotation quality: RefSeq or Ensembl annotations are more reliable than
##     automated genome-only predictions. Avoid references where the annotation
##     itself was produced by the same gene caller you are trying to fix.
##
##   Phylogenetic distance: closer is better for hit sensitivity, but too close
##     risks inheriting the same annotation errors (a gene split in both the
##     query and the reference will produce no tiling signal at all). A rough
##     rule: use the closest well-annotated species available, not the closest
##     sequenced species.
##
##   Isoform representation: if the reference proteome includes many isoforms
##     per gene (Ensembl typically does), num_tiling_hits will be higher for
##     multi-copy and multi-isoform gene families. This inflates hit counts for
##     those families relative to single-copy genes. Proteomes filtered to one
##     canonical protein per gene give more comparable hit counts across families,
##     but reduce total sensitivity. Choose based on whether you want hit counts
##     to be comparable (filtered) or maximally sensitive (all isoforms).
##
##   Multi-proteome strategy: running this pipeline against two independent
##     reference proteomes and taking the intersection of supported merge
##     candidates provides substantially stronger evidence than a single reference.
##     Pairs supported by both references are the most reliable. Pairs supported
##     by only one reference warrant closer inspection.
##     See README for the consensus_merge_candidates.txt workflow.
##
## Suggested references by taxon (in rough priority order):
##   Squamates:  Anolis carolinensis (RefSeq / Ensembl), Pogona vitticeps (Ensembl)
##   Mammals:    human (GRCh38 RefSeq), mouse (GRCm39 RefSeq)
##   Birds:      chicken (GRCg7b RefSeq), zebra finch
##   Fish:       zebrafish (GRCz11 RefSeq), medaka
##
subject_fa = anolis_proteome.fa

## IsoSeq GFF file (mRNA features from long-read transcriptome).
## Used in step 3 (bedtools) and step 5 (IsoSeq validation).
## Leave blank to skip IsoSeq steps — pipeline will use protein evidence only.
isoseq_gff =

## Transcript->gene mapping is derived automatically from the input GFF.

## ============================================================
[output]

## Name for the merged output GFF3 file.
output_gff = new_merges.gff

## Name for the removed source genes GFF3 file (audit trail).
removed_gff = removed_genes.gff

## Working directory for intermediate files.
## Will be created if it does not exist.
workdir = mender_workdir

## ============================================================
[diamond]

## Number of threads for diamond blastp.
threads = 4

## E-value cutoff for diamond blastp.
## Only hits with evalue <= this value are kept.
evalue = 1e-20

## NOTE on diamond output format:
## The pipeline requires these fields in this order:
##   qseqid sseqid pident length mismatch gapopen qstart qend
##   sstart send evalue bitscore scovhsp slen qcovhsp qlen
##
## qcovhsp (query coverage per HSP) and qlen (query sequence length) are
## required to enable the soft fragment filter in find_split_genes.pl.
## This filter catches split fragments of shorter proteins (86-89% scovhsp)
## that the classic scovhsp-only filter would exclude. If your diamond
## version does not support qcovhsp, remove it from the --outfmt string
## in run_mender.pl — the classic filter (scovhsp <= 85%) will apply.
##
## run_mender.pl builds the correct --outfmt string automatically.

## ============================================================
[ids]

##
## New gene and transcript ID templates using bracket notation.
## [GCOUNT:N]  gene counter, zero-padded to N digits
## [TCOUNT:N]  transcript counter, zero-padded to N digits
## [DATE]      today's date in YYYYMMDD format (substituted at runtime)
## All other text is literal.
##
## Leave as default for a date-stamped safe ID that works for any organism.
## For organism-specific IDs that match your annotation convention,
## supply templates that match your existing ID format.
##
## Examples:
##   CCA3 chameleon style:
##     gene_template  = CCA3g1[GCOUNT:6]000
##     trans_template = CCA3t1[GCOUNT:6][TCOUNT:3]
##
##   Generic Helixer bat genome (e.g. ACI1_HiC_scaffold_1_000001):
##     gene_template  = ACI1_HiC_scaffold_1_[GCOUNT:6]
##     trans_template = ACI1_HiC_scaffold_1_[GCOUNT:6].[TCOUNT]
##
##   Medicago style (MS.gene00001 / MS.gene00001.t1):
##     gene_template  = MS.gene[GCOUNT:5]
##     trans_template = MS.gene[GCOUNT:5].t[TCOUNT]
##
##   Trinity style:
##     gene_template  = TRINITY_DN1000_c115_g[GCOUNT]
##     trans_template = TRINITY_DN1000_c115_g[GCOUNT]_i[TCOUNT]
##
## Note: version suffix (e.g. .1) is intentionally excluded.
## New genes are always version 1. Versions increment only when
## manually editing exon boundaries after the initial merge.

gene_template  = MERGE[DATE]g[GCOUNT:6]000
trans_template = MERGE[DATE]t[GCOUNT:6][TCOUNT:3]

## ============================================================
[merge_filters]
##
## Filters applied when deciding which merge candidates to act on.
## These correspond to --flags, --skip_flags etc in merge_split_genes.pl.

## fix_partial: yes/no
## When yes, PARTIAL_SPAN merges have their unsupported terminal gene(s)
## trimmed before merging. A PARTIAL_SPAN merge has IsoSeq reads that
## span some but not all genes in the merge group, indicating a terminal
## gene may not belong. The supported subset is merged; the unsupported
## terminal is left as-is.
fix_partial = yes

## skip_flags: comma-separated list of flags to exclude from merging.
## Rows whose flag column contains any of these terms are skipped.
##
## Available flags:
##   SKIPPED_GENE         a non-adjacent gene sits inside the merge locus
##                        — review manually before merging (recommended to skip)
##   LOW_COV              combined coverage < 60% — may be domain sharing, not a split gene
##                        — generally safe to skip
##   SINGLE_HIT           exactly 1 tiling hit at all junctions
##                        — this is a REVIEW flag, not a default skip. For single-copy
##                          genes in the reference, 1 hit is the expected maximum.
##                          Inspect hit_desc and pident before deciding. Skip only if
##                          the hit is against a generic multi-domain protein with low
##                          identity and you have no IsoSeq support.
##   TRANSITIVE_JOIN      consecutive genes in the chain have no direct tiling evidence;
##                        connection is inferred transitively. STRONG,TRANSITIVE_JOIN
##                        merges should be treated with caution — verify with IsoSeq.
##   MULTI_ISOFORM_JOIN   at least one source gene has multiple transcripts; merged gene
##                        will contain cross-product isoform combinations not all of
##                        which may be real.
##   LARGE_SPAN           merged locus > large_span_warn (default 500kb)
##   LARGE_SPAN_EXTREME   merged locus > large_span_extreme (default 2Mb)
##                        — strongly recommended to skip unless IsoSeq confirms
##   WEAK_END             terminal junction has 1-2 tiling hits but survived trimming
##   WEAK_INTERNAL        internal junction has 1-2 hits but survived splitting
##   STRONG               all junctions >= 3 tiling hits — you would NOT skip this
##   CLEAN                directly adjacent, 2+ hits, coverage >= 60% — no concerns flagged
##
## Conservative run (protein evidence only, no IsoSeq):
##   skip_flags = SKIPPED_GENE,LOW_COV,SINGLE_HIT,TRANSITIVE_JOIN,LARGE_SPAN_EXTREME
##
## Liberal run (then validate merges with translation/MSA step):
##   skip_flags = LOW_COV
##   (use the translation validation output to filter the result)
##
skip_flags = SKIPPED_GENE,LOW_COV

## large_span_warn: merged locus genomic span (bp) above which LARGE_SPAN is flagged.
## Set to 0 to disable. Default: 500000 (500 kb).
large_span_warn = 500000

## large_span_hard: merged locus genomic span (bp) above which LARGE_SPAN_EXTREME
## is flagged. Set to 0 to disable. Default: 2000000 (2 Mb).
large_span_hard = 2000000

## flags: include filter — only process rows whose flag matches one of these.
## Use 'all' to process all rows (subject to skip_flags above).
## Example: flags = STRONG  — only merge STRONG candidates
flags = all

## min_tiling: minimum max_tiling_hits value to process a merge candidate.
## 1 = no minimum (process all). Higher values require stronger protein evidence.
## Suggested: 1 (rely on IsoSeq and flags instead)
min_tiling = 1

## min_cov: minimum combined_cov_pct to process a merge candidate.
## 0 = no minimum. 60 would exclude LOW_COV cases (redundant if LOW_COV is
## already in skip_flags).
min_cov = 0

## require_isoseq: only process rows with this exact isoseq_flag value.
## Leave blank to process all rows regardless of IsoSeq status.
## Options: FULL_SPAN, PARTIAL_SPAN, none
## Example: require_isoseq = FULL_SPAN  — only IsoSeq-confirmed merges
require_isoseq =

## isoseq_min_spanning: minimum number of spanning IsoSeq reads required.
## 0 = no minimum. Only meaningful if isoseq_gff was provided.
## Example: isoseq_min_spanning = 3  — require at least 3 spanning reads
isoseq_min_spanning = 0

## asym_trim: yes/no (default yes)
## Controls whether find_split_genes.pl trims or splits multi-gene chains
## at weak asymmetric junctions (1 tiling hit where the strong side has
## >= 6 hits). When yes, weak terminal genes are dropped and weak internal
## junctions cause splits; the dropped genes are silently excluded from the
## merge table. When no, chains are kept whole and the weak-end genes appear
## in the output with a WEAK_END flag so you can review them manually.
##
## Consider setting to 'no' when:
##   - Your reference proteome is phylogenetically distant (fewer tiling hits
##     overall, so the asymmetry threshold of 6 is rarely reached).
##   - You want to see what would be trimmed before deciding to discard it.
##   - You are comparing two runs to evaluate the effect of trimming.
asym_trim = yes

## max_dist: maximum number of gene rank positions between two candidate
## fragments for them to be considered a tiling pair. Nested genes are
## excluded from the rank before this is evaluated, so max_dist counts
## only real intervening genes (see SKIPPED_GENE flag).
## Increase for gene-sparse assemblies (highly fragmented or repeat-rich
## genomes where split fragments may be further apart); decrease to reduce
## false positives in very gene-dense regions. Values above 4 substantially
## increase the number of SKIPPED_GENE candidates and run time.
## Default: 4
max_dist = 4

## wiggle: maximum allowed gap or overlap between the two fragment alignments,
## measured in amino acids on the reference protein. A positive value means a
## gap between the two HSPs (they don't quite meet); a negative value means they
## overlap slightly. Both are expected from normal HSP boundary fuzziness.
## Increase for distant reference proteomes where alignment ends are less sharp;
## decrease if you are seeing spurious pairs where the two alignments don't
## cleanly partition the reference.
## Default: 15
wiggle = 15

## asym_threshold: minimum tiling-hit count on the strong side of a chain
## junction needed to trigger asymmetric trimming of a weak terminal gene.
## A junction is trimmed when it has exactly 1 tiling hit AND another junction
## in the same chain has >= asym_threshold hits. Raise this value when your
## reference proteome is small or phylogenetically distant, so that low hit
## counts are expected even for real junctions. Only applies when asym_trim = yes.
## Default: 6
asym_threshold = 6

## low_cov_thresh: combined_cov_pct (the fraction of the reference protein
## spanned by the two fragments together) below which the LOW_COV flag is
## assigned. Pairs with very low combined coverage are more likely to reflect
## domain sharing than a genuine split gene. This controls the flag only —
## candidates are not removed unless LOW_COV is in skip_flags.
## Default: 60 (percent)
low_cov_thresh = 60

## ============================================================
[validation]
##
## Optional validation steps run after merging.
## Steps 7 (gt) and 9 (agat) require gt (GenomeTools) and agat to be installed.
## Step 8 (translation validation) requires gffread, diamond, and mafft.
## These steps are validation only — they do not modify the output GFF.

## run_gt: yes/no — run gt gff3validator on the full merged GFF (step 7, fast).
## Checks strict GFF3 spec compliance. Useful for catching frame issues.
run_gt = yes

## run_translation_validation: yes/no — run validate_merge_translation.pl (step 8).
## Translates merged proteins, runs diamond + MAFFT, assigns PASS/FAIL/REVIEW.
## Produces _pass.gff3, _fail.gff3, _review.gff3 subsets.
## Set to no to skip (e.g. when genome_fa is unavailable or for a quick run).
run_translation_validation = yes

## min_junction_score: minimum per-junction MSA score for a merge to PASS.
## Range 0.0–1.0. Higher = stricter. Default: 0.5.
min_junction_score = 0.5

## min_merged_cov: minimum fraction of merged protein covered by best ref hit.
## Default: 0.60 (relaxed vs the 0.85 fragment filter in find_split_genes.pl).
min_merged_cov = 0.60

## min_ref_cov: minimum fraction of best ref protein covered by merged protein.
## Default: 0.50.
min_ref_cov = 0.50

## no_msa: yes/no — skip MSA entirely; report translation + diamond only.
## Faster but loses junction scoring. PASS requires GOOD_MSA unless no_msa = yes.
no_msa = no

## aligner: MSA tool and strategy for junction scoring.
##   mafft_fast  (default) — mafft --retree 2 --maxiterate 0
##                           FFT-NS-2; no iterative refinement.
##                           ~2–3× faster than mafft_auto; effectively identical
##                           accuracy for small sets of related proteins.
##   mafft_auto  — mafft --auto; slower but uses the most accurate MAFFT
##                 strategy for the input size. Recommended for keep_msa = yes
##                 (inspection runs where you read the alignments by eye).
##   kalign3     — kalign3 progressive aligner; ~5–10× faster than mafft_auto.
##                 Requires kalign to be in PATH or set via kalign_bin below.
##                 Accuracy slightly lower for divergent sequences; suitable
##                 when speed matters more than fine-grained junction scoring.
aligner = mafft_fast

## MSA junction scoring weights.
## Three sub-scores are combined into a single junction score (range 0–1):
##   w_conservation — fraction of positions in the ±5 aa window where the merged
##                    protein and reference sequences agree on the majority residue.
##                    Computed over merged + refs only (source fragments excluded).
##   w_continuity   — fraction of reference sequences that are completely gap-free
##                    across the ±5 aa junction window.  Measures whether the junction
##                    falls in a well-conserved region of the protein family.
##   w_gap          — fraction of window columns where the merged protein does NOT
##                    introduce a gap relative to reference sequences.  The most
##                    direct measure of merge-introduced alignment disruption.
##
## Weights must sum to exactly 1.0.  The defaults give equal weight to
## conservation and continuity and slightly more to the gap penalty, which is
## the most principled of the three metrics.
w_conservation = 0.3
w_continuity   = 0.3
w_gap          = 0.4

## min_msa_refs: minimum number of reference sequences required in the MSA for
## the junction score to be considered fully reliable.  When fewer refs are
## available, the merge is still scored but flagged GOOD_MSA_LOW_REF (instead of
## GOOD_MSA) and a warning is written to STDERR.  The PASS/FAIL/REVIEW outcome
## is unchanged — the flag lets you filter low-confidence calls in the TSV.
## Set to 1 to suppress warnings for single-reference alignments.
min_msa_refs = 2

## max_msa_refs: maximum number of reference sequences to include in each MSA.
## Diamond is run with --max-target-seqs 5, so values above 5 have no effect
## unless you also increase the diamond search depth.  More refs improve the
## robustness of the junction score (especially the gap-pattern metric), but
## very distant homologs in positions 4–5 can dilute conservation signal.
## Default: 3.  Increase to 5 to use all available diamond hits.
max_msa_refs = 3

## keep_msa: yes/no — write per-merge alignment files to <transl_out_prefix>_msa/.
## Useful for inspecting individual junction alignments. Disk-intensive on large runs.
keep_msa = no

## transl_out_prefix: output file prefix for translation validation results.
## Leave blank to use <workdir>/transl (e.g. mender_workdir/transl).
transl_out_prefix =

## swissprot_fa: path to UniProt/SwissProt FASTA for MSA reference sequences.
## Manually curated proteins give better junction scoring than the species
## reference proteome (no partial sequences, no annotation errors).
## Falls back to ref_fa sequences if blank or file not found.
##
## To download SwissProt:
##   wget https://ftp.uniprot.org/pub/databases/uniprot/current_release/knowledgebase/complete/uniprot_sprot.fasta.gz
##   gunzip uniprot_sprot.fasta.gz
##   diamond makedb --in uniprot_sprot.fasta --db uniprot_sprot.dmnd
swissprot_fa =

## swissprot_db: pre-built diamond DB from swissprot_fa (built automatically if blank).
swissprot_db =

## final_gff_include_review: yes/no — include REVIEW merges in the final validated GFF.
## REVIEW merges passed basic translation checks but have borderline MSA junction scores.
## yes (default): REVIEW merges are kept — trusts IsoSeq + tiling evidence; MSA flag is
##                informational. Recommended when IsoSeq data is available.
## no: REVIEW merges are replaced with source genes — requires a clean MSA score to be
##     included. More conservative; use when IsoSeq coverage is sparse.
final_gff_include_review = yes

## run_agat: yes/no — run agat_convert_sp_gxf2gxf.pl (step 9, slow).
## Runs on the _pass.gff3 from step 8 (or full merged GFF if step 8 was skipped).
## Checks gene-model consistency (CDS/exon structure, orphan features, etc).
## Output is discarded (/dev/null) — only warnings and errors are reported.
run_agat = yes

## ============================================================
[paths]
##
## Paths to scripts and tools. Leave blank to use whatever is in $PATH.
## Useful if you have multiple versions installed or non-standard locations.

## Path to Mender scripts directory.
## Leave blank if running from the same directory as the scripts.
scripts_dir =

## Explicit paths to tools (leave blank to use $PATH).
## Note about agat_bin: if updating path, include agat_convert_sp_gxf2gxf.pl
diamond_bin    =
bedtools_bin   =
gt_bin         =
agat_bin       =
gffread_bin    =
mafft_bin      =
kalign_bin     =
perl_bin       =
